{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default Config",
            "description": "Default release build with tests enabled",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CGS_BUILD_TESTS": "ON",
                "CGS_BUILD_BENCHMARKS": "OFF",
                "CGS_BUILD_SERVICES": "OFF"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build with tests and coverage enabled",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CGS_BUILD_TESTS": "ON",
                "CGS_BUILD_BENCHMARKS": "ON",
                "CGS_ENABLE_COVERAGE": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Optimized release build (no tests)",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CGS_BUILD_TESTS": "OFF",
                "CGS_BUILD_BENCHMARKS": "OFF"
            }
        },
        {
            "name": "asan",
            "displayName": "AddressSanitizer",
            "description": "Build with AddressSanitizer + UBSan",
            "inherits": "debug",
            "binaryDir": "${sourceDir}/build-asan",
            "cacheVariables": {
                "CGS_ENABLE_SANITIZERS": "ON"
            }
        },
        {
            "name": "tsan",
            "displayName": "ThreadSanitizer",
            "description": "Build with ThreadSanitizer",
            "inherits": "debug",
            "binaryDir": "${sourceDir}/build-tsan",
            "cacheVariables": {
                "CMAKE_CXX_FLAGS": "-fsanitize=thread",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread"
            }
        },
        {
            "name": "ci",
            "displayName": "CI Build",
            "description": "Configuration for continuous integration (RelWithDebInfo + tests + benchmarks)",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-ci",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CGS_BUILD_TESTS": "ON",
                "CGS_BUILD_BENCHMARKS": "ON",
                "CGS_BUILD_SERVICES": "ON"
            }
        },
        {
            "name": "conan-release",
            "displayName": "Conan Release",
            "description": "Release build with Conan-provided dependencies",
            "binaryDir": "${sourceDir}/build/Release",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/Release/generators/conan_toolchain.cmake",
                "CMAKE_BUILD_TYPE": "Release",
                "CGS_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "conan-debug",
            "displayName": "Conan Debug",
            "description": "Debug build with Conan-provided dependencies",
            "binaryDir": "${sourceDir}/build/Debug",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/Debug/generators/conan_toolchain.cmake",
                "CMAKE_BUILD_TYPE": "Debug",
                "CGS_BUILD_TESTS": "ON",
                "CGS_ENABLE_COVERAGE": "ON"
            }
        }
    ],
    "buildPresets": [
        {"name": "default", "configurePreset": "default"},
        {"name": "debug", "configurePreset": "debug"},
        {"name": "release", "configurePreset": "release"},
        {"name": "asan", "configurePreset": "asan"},
        {"name": "tsan", "configurePreset": "tsan"},
        {"name": "ci", "configurePreset": "ci"},
        {"name": "conan-release", "configurePreset": "conan-release"},
        {"name": "conan-debug", "configurePreset": "conan-debug"}
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "output": {"outputOnFailure": true}
        },
        {
            "name": "ci",
            "configurePreset": "ci",
            "output": {"outputOnFailure": true, "verbosity": "verbose"}
        },
        {
            "name": "conan-release",
            "configurePreset": "conan-release",
            "output": {"outputOnFailure": true}
        }
    ]
}
